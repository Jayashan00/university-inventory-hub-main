# University Inventory Hub - Environment Configuration

## MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/inventory_hub
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/inventory_hub

## JWT Configuration
JWT_SECRET=university-inventory-hub-secret-key-change-in-production
JWT_EXPIRATION=86400000

## Server Configuration
SERVER_PORT=8085
SERVER_CONTEXT_PATH=/api

## Frontend Configuration
VITE_API_BASE_URL=http://localhost:8085/api

## Logging
LOG_LEVEL=INFO

